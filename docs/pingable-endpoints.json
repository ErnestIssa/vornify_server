{
  "_description": "Read-only or safe GET endpoints for cron pings to keep database and server awake. No POST/PUT/DELETE that modify state. Use with base URL (e.g. https://your-api.render.com).",
  "_note": "Endpoints with :param or ?query require substitution. auth_required indicates Bearer token needed.",
  
  "storefront": {
    "description": "Public storefront endpoints - no auth required",
    "products": [
      "/api/products",
      "/api/products?limit=5",
      "/api/products/most-viewed",
      "/api/products/most-viewed?limit=6",
      "/api/products/categories",
      "/api/products/sitemap",
      "/api/products/:id",
      "/api/products/:id/variants",
      "/api/products/:id?currency=SEK"
    ],
    "reviews": [
      "/api/reviews",
      "/api/reviews?limit=10",
      "/api/reviews?productId={productId}",
      "/api/reviews?status=approved",
      "/api/reviews/:id"
    ],
    "currency": [
      "/api/convert?amount=100&from=EUR&to=SEK",
      "/api/settings/currencies"
    ],
    "shipping": [
      "/api/shipping/methods",
      "/api/shipping/fraktjakt-service-point-locator?country=se"
    ],
    "content": [
      "/api/admin/content"
    ]
  },

  "seo": {
    "description": "SEO and crawler endpoints",
    "endpoints": [
      "/meta-feed.csv",
      "/api/products/sitemap",
      "/robots.txt"
    ]
  },

  "meta": {
    "description": "Meta Commerce Manager and feeds",
    "endpoints": [
      "/meta-feed.csv"
    ]
  },

  "health": {
    "description": "Health and diagnostic endpoints - lightweight, no DB",
    "endpoints": [
      "/health",
      "/",
      "/api/support/test",
      "/api/storage/test",
      "/.well-known/apple-developer-merchantid-domain-association"
    ]
  },

  "health_with_db": {
    "description": "Endpoints that hit the database - use these for DB wake-up",
    "endpoints": [
      "/api/products",
      "/api/products/categories",
      "/api/products/sitemap",
      "/meta-feed.csv",
      "/api/reviews",
      "/api/settings/currencies",
      "/api/admin/content"
    ]
  },

  "admin": {
    "description": "Admin endpoints - require Authorization: Bearer <token>",
    "auth_required": true,
    "products": [
      "/api/products",
      "/api/products?limit=5",
      "/api/products/categories",
      "/api/products/most-viewed",
      "/api/products/:id",
      "/api/products/:id/variants"
    ],
    "reviews": [
      "/api/reviews",
      "/api/reviews/analytics"
    ],
    "orders": [
      "/api/orders/all",
      "/api/orders/verify-email?email=test@example.com"
    ],
    "customers": [
      "/api/customers",
      "/api/customers/analytics"
    ],
    "newsletter": [
      "/api/newsletter/subscribers",
      "/api/newsletter/analytics"
    ],
    "admin_panel": [
      "/api/admin/me",
      "/api/admin/me/activity",
      "/api/admin/check-newsletter-subscribers",
      "/api/admin/notifications"
    ]
  },

  "other_read_only": {
    "description": "Other safe GET endpoints - may require specific params or auth",
    "orders": [
      "/api/orders/verify-email?email=test@example.com",
      "/api/orders/track?email=test@example.com&orderId=dummy",
      "/api/orders/all"
    ],
    "tracking": [
      "/api/tracking/track/:trackingNumber",
      "/api/tracking/orders/:orderId",
      "/api/tracking/history/:trackingNumber"
    ],
    "checkout": [
      "/api/checkout/recover/:checkoutId",
      "/api/checkout/diagnostic"
    ],
    "payment": [
      "/api/payments/check-payment-methods",
      "/api/payments/config",
      "/api/payments/status/:paymentIntentId",
      "/api/payments/apple-pay/verification-file",
      "/api/apple-pay/test-route",
      "/api/apple-pay/verify"
    ],
    "email": [
      "/api/email/stats",
      "/api/email/logs",
      "/api/email/verify",
      "/api/email/verify/status",
      "/api/email/diagnostics"
    ],
    "waitlist": [
      "/api/waitlist/stats"
    ],
    "payment_failure": [
      "/api/payment-failure/recover/:retryToken"
    ],
    "admin_auth": [
      "/api/admin/auth/diagnostic"
    ]
  },

  "recommended_for_cron": {
    "description": "Minimal set - no auth, no path params, hits DB. Use these for Render/cron wake-up.",
    "primary": [
      "/health",
      "/api/products",
      "/api/products/categories",
      "/api/products/sitemap",
      "/meta-feed.csv",
      "/api/reviews",
      "/api/settings/currencies",
      "/api/admin/content"
    ],
    "fallback_if_primary_fail": [
      "/api/shipping/methods",
      "/api/convert?amount=1&from=EUR&to=SEK"
    ]
  },

  "utility_cron": {
    "description": "GET alias for jobs that only support GET (e.g. cron-job.org). Currency update refreshes rates from ECB/USD API.",
    "endpoints": [
      "/api/settings/currencies/update"
    ]
  }
}
